NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set this to your canonical domain so password-reset emails always link
# to the correct URL even when the page is loaded from a preview deployment.
# Example: https://goodtally.app
NEXT_PUBLIC_SITE_URL=https://goodtally.app

# Sentry error monitoring (get DSN from sentry.io after creating project)
NEXT_PUBLIC_SENTRY_DSN=

# Stripe — get keys from dashboard.stripe.com → Developers → API keys
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook` locally
# For production: register endpoint in Stripe Dashboard → Developers → Webhooks
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_COUPON_EARLY_ADOPTER=EARLYBIRD
STRIPE_COUPON_RETENTION=RETENTION25

# Resend — transactional email. Required in production.
# Sign up at https://resend.com, verify the goodtally.app domain
# (SPF, DKIM, DMARC, return-path CNAME — see docs/DNS_SETUP.md), then
# create an API key and paste it here.
RESEND_API_KEY=

# Super-admin allowlist: comma-separated Supabase auth user IDs that can
# access /super and mutate feature request statuses. Editing this env
# var is the only way to change the list — intentional friction.
SUPER_ADMIN_USER_IDS=

# Shared secret for cron endpoints (/api/cron/*). Generate with
# `openssl rand -hex 32`. The cron scheduler must send
# `Authorization: Bearer <CRON_SECRET>` on every request.
CRON_SECRET=
