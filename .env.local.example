NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Set this to your canonical domain so password-reset emails always link
# to the correct URL even when the page is loaded from a preview deployment.
# Example: https://goodtally.app
NEXT_PUBLIC_SITE_URL=https://goodtally.app

# Sentry error monitoring (get DSN from sentry.io after creating project)
NEXT_PUBLIC_SENTRY_DSN=
